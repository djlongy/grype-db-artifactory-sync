# Copy to .env and fill in — `make sync` / `make test-local` will source it.
# .env is gitignored. NEVER commit real credentials.

# --- Artifactory (required) ---
ARTIFACTORY_URL=https://artifactory.example.com
ARTIFACTORY_REPO=grype-db-local
ARTIFACTORY_USER=svc-grype
ARTIFACTORY_TOKEN=changeme

# --- Egress proxy (optional) ---
# Set to route the anchore.io fetch through Squid / an enterprise proxy.
# Leave empty for direct internet. NO_PROXY should list internal hosts so
# uploads to Artifactory bypass the proxy.
# HTTPS_PROXY=http://squid.example.com:3128
# HTTP_PROXY=http://squid.example.com:3128
# NO_PROXY=.example.com,artifactory.example.com

# --- Source overrides (optional) ---
# Mode A (default): pull straight from anchore via the egress proxy.
# GRYPE_DB_SOURCE_URL=https://grype.anchore.io/databases/v6/latest.json
# GRYPE_DB_SUBPATH=databases/v6
#
# Mode B: pull from your Artifactory REMOTE repo and push to the LOCAL repo, so
# build agents never egress (only Artifactory does). Point the source at the
# remote repo's latest.json and enable source auth (reuses ARTIFACTORY_USER/TOKEN):
# GRYPE_DB_SOURCE_URL=https://artifactory.example.com/artifactory/grype-db-remote/v6/latest.json
# GRYPE_DB_SOURCE_AUTH=1

# --- Behaviour (optional) ---
# DRY_RUN=1   # download + verify but do not upload
