# Copy to .env and fill in — `make sync` / `make test-local` will source it.
# .env is gitignored. NEVER commit real credentials.

# --- Artifactory (required) ---
ARTIFACTORY_URL=https://artifactory.example.com
ARTIFACTORY_REPO=grype-db-local
ARTIFACTORY_USER=svc-grype
ARTIFACTORY_TOKEN=changeme

# --- Egress proxy (optional) ---
# Set to route the anchore.io fetch through Squid / an enterprise proxy.
# Leave empty for direct internet. NO_PROXY should list internal hosts so
# uploads to Artifactory bypass the proxy.
# HTTPS_PROXY=http://squid.example.com:3128
# HTTP_PROXY=http://squid.example.com:3128
# NO_PROXY=.example.com,artifactory.example.com

# --- Source mode (optional) ---
# Mode A (default): pull straight from anchore via the egress proxy. Nothing to set.
#
# Mode B: pull from your Artifactory REMOTE repo and push to the LOCAL repo, so build
# agents never egress (only Artifactory does). The remote repo points at the bare
# https://grype.anchore.io host, so remote and local share the same databases/v6 layout.
# Set ONLY this — auth is automatic (source host = your Artifactory) and the publish
# path mirrors the source object path (databases/v6):
# GRYPE_DB_SOURCE_URL=https://artifactory.example.com/artifactory/grype-db-remote/databases/v6/latest.json

# --- Advanced overrides (rarely needed) ---
# GRYPE_DB_SOURCE_AUTH=auto   # auto | true | false  (default auto)
# GRYPE_DB_SUBPATH=databases/v6   # default mirrors the source URL's path
# GRYPE_DB_SOURCE_URL=https://grype.anchore.io/databases/v6/latest.json

# --- Behaviour (optional) ---
# DRY_RUN=1   # download + verify but do not upload
